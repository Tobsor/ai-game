AI_PROFILE=local_current_hardcoded

# local_current_hardcoded reproduces the current exact setup:
# decision=qwen3:4b-instruct-2507-q8_0
# response=nollama/mythomax-l2-13b:Q4_K_M
# judge=mistral:7b-instruct-v0.3-q8_0
# embedding=mxbai-embed-large

# Local Chroma stays local-only.
CHROMA_PATH=./faction_db
CHROMA_COLLECTION=factions
CHROMA_DISTANCE_SPACE=cosine

# Optional per-role overrides:
# DECISION_PROVIDER=ollama
# DECISION_MODEL=qwen3:4b-instruct-2507-q8_0
# RESPONSE_PROVIDER=ollama
# RESPONSE_MODEL=nollama/mythomax-l2-13b:Q4_K_M
# JUDGE_PROVIDER=ollama
# JUDGE_MODEL=mistral:7b-instruct-v0.3-q8_0
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=mxbai-embed-large

# Example hosted setup:
# AI_PROFILE=remote_llm_local_chroma
# DECISION_PROVIDER=huggingface
# DECISION_MODEL=<hf-model-id>
# DECISION_BASE_URL=<hf-chat-endpoint>
# DECISION_API_KEY_ENV=HF_TOKEN
# RESPONSE_PROVIDER=openai_compatible
# RESPONSE_MODEL=<remote-chat-model>
# RESPONSE_BASE_URL=<openai-compatible-chat-endpoint>
# RESPONSE_API_KEY_ENV=OPENAI_API_KEY
